# ============================================================
# SkillBin — Environment Variables Template
#
# USAGE:  Copy this file to .env and fill in real values.
#         NEVER commit .env — it is in .gitignore.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Matches the docker-compose.yml defaults below.
# Change user/password/host/port if using a remote or custom DB.
DATABASE_URL=postgresql://skillbin:skillbin@localhost:5432/skillbin

# ── Anthropic / Claude API ───────────────────────────────────
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── JWT Auth ──────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use the placeholder below in production.
JWT_SECRET=REPLACE_ME_with_a_64_char_random_hex_string

# ── CORS ─────────────────────────────────────────────────────
# Frontend dev server origin. Update for production.
CORS_ORIGIN=http://localhost:5173
