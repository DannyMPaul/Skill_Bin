# ============================================================
# SkillBin .gitignore
# NEVER commit .env — it contains real secrets.
# ============================================================

# ── Environment / Secrets ───────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# uv
.uv/

# ── Testing / Coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ── Alembic ──────────────────────────────────────────────────
# Keep the versions directory but ignore compiled cache inside it
backend/alembic/versions/__pycache__/

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Docker ───────────────────────────────────────────────────
# Keep docker-compose.yml but ignore local overrides
docker-compose.override.yml

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
